{
  "name": "smart_conversation",
  "description": "If characters exist: narrator (scene only), NPC lines, narrator_coda (player prompt), condense, memory. If no characters: narrator (full beat + prompt), condense, memory — skips npc and narrator_coda.",
  "nodes": ["narrator", "npc", "narrator_coda", "condense", "memory"],
  "entry_point": {
    "router": "route_graph_entry",
    "mapping": {
      "narrator": "narrator"
    }
  },
  "edges": [
    { "from": "npc", "to": "narrator_coda" },
    { "from": "narrator_coda", "to": "condense" },
    { "from": "condense", "to": "memory" },
    { "from": "memory", "to": "__end__" }
  ],
  "conditional_edges": [
    {
      "from": "narrator",
      "router": "route_after_narrator",
      "mapping": {
        "npc": "npc",
        "condense": "condense"
      }
    }
  ]
}
