{
  "name": "conversation_with_mood",
  "description": "Narrator responds, mood shifts tracked, NPCs speak in character, then condense and memory. Skips mood+NPC if no characters.",
  "nodes": ["narrator", "mood", "npc", "condense", "memory"],
  "entry_point": {
    "router": "route_graph_entry",
    "mapping": {
      "narrator": "narrator"
    }
  },
  "edges": [
    { "from": "mood", "to": "npc" },
    { "from": "npc", "to": "condense" },
    { "from": "condense", "to": "memory" },
    { "from": "memory", "to": "__end__" }
  ],
  "conditional_edges": [
    {
      "from": "narrator",
      "router": "route_after_narrator",
      "mapping": {
        "npc": "mood",
        "condense": "condense"
      }
    }
  ]
}
