{
  "name": "flux_default",
  "description": "Flux Dev FP8 — general purpose SFW image generation",
  "checkpoint": "flux1-dev-fp8.safetensors",
  "workflow": {
    "3": {
      "class_type": "KSampler",
      "inputs": {
        "cfg": 1.0,
        "denoise": 1.0,
        "latent_image": ["5", 0],
        "model": ["4", 0],
        "negative": ["7", 0],
        "positive": ["6", 0],
        "sampler_name": "euler",
        "scheduler": "normal",
        "seed": 0,
        "steps": 20
      }
    },
    "4": {
      "class_type": "CheckpointLoaderSimple",
      "inputs": { "ckpt_name": "flux1-dev-fp8.safetensors" }
    },
    "5": {
      "class_type": "EmptyLatentImage",
      "inputs": { "batch_size": 1, "height": 500, "width": 800 }
    },
    "6": {
      "class_type": "CLIPTextEncode",
      "inputs": { "clip": ["4", 1], "text": "" }
    },
    "7": {
      "class_type": "CLIPTextEncode",
      "inputs": { "clip": ["4", 1], "text": "" }
    },
    "8": {
      "class_type": "VAEDecode",
      "inputs": { "samples": ["3", 0], "vae": ["4", 2] }
    },
    "9": {
      "class_type": "SaveImage",
      "inputs": { "filename_prefix": "rpg", "images": ["8", 0] }
    }
  },
  "settings": {
    "cfg": 1.0,
    "steps": 20,
    "sampler_name": "euler",
    "scheduler": "normal",
    "negative_prompt": ""
  },
  "notes": "Flux Dev FP8 works best with cfg=1.0 and euler sampler. No negative prompt needed. Good at environments, architecture, and atmospheric scenes."
}
