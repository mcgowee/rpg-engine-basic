# === LLM Provider ===
# "ollama" for local development, "azure" for hosted/public deployment
LLM_PROVIDER=ollama

# === Ollama (used when LLM_PROVIDER=ollama) ===
OLLAMA_HOST=http://localhost:11434
DEFAULT_MODEL=nchapman/mn-12b-mag-mell-r1:latest

# === Azure (used when LLM_PROVIDER=azure) ===
AZURE_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_API_KEY=your-api-key-here
AZURE_DEPLOYMENT=gpt-4o-mini
AZURE_API_VERSION=2024-12-01-preview

# === Flask ===
FLASK_HOST=0.0.0.0
FLASK_PORT=5051
FLASK_DEBUG=false
SECRET_KEY=change-this-to-a-random-string-in-production
# HTTPS behind a reverse proxy: set true so session cookies are Secure
# SESSION_COOKIE_SECURE=true

# === Database ===
# DATABASE_PATH=./rpg.db

# === Game ===
HISTORY_LIMIT=6
SAVE_SLOTS=5
INVENTORY_WEIGHT_LIMIT=10
LOG_LEVEL=INFO
